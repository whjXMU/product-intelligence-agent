{
  "name": "@product-intelligence-agent/agent-mvp",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "description": "Agent MVP：基于手动 HTML 输入的竞品首页分析实验包",
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "scripts": {
    "dev": "tsx src/index.ts",
    "dev:watch": "tsx watch src/index.ts",
    "build": "tsc -p tsconfig.json",
    "typecheck": "tsc -p tsconfig.json --noEmit",
    "lint": "tsc -p tsconfig.json --noEmit",
    "start": "pnpm build && node dist/index.js"
  },
  "devDependencies": {
    "@types/node": "^24.0.0",
    "tsx": "^4.22.4",
    "typescript": "^5.8.3"
  },
  "dependencies": {
    "cheerio": "^1.2.0",
    "html-to-text": "^10.0.0",
    "openai": "^6.44.0",
    "zod": "^4.4.3"
  }
}

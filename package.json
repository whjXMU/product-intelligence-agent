{
  "name": "product-intelligence-agent",
  "version": "0.1.0",
  "private": true,
  "description": "辅助产品经理进行 AI 产品文档竞品分析的 Agent 应用",
  "packageManager": "pnpm@8.15.9",
  "scripts": {
    "dev": "pnpm -r --parallel dev",
    "dev:web": "pnpm --filter @product-intelligence-agent/web dev",
    "dev:api": "pnpm --filter @product-intelligence-agent/api start:dev",
    "build": "pnpm -r build",
    "typecheck": "pnpm -r typecheck",
    "lint": "pnpm -r lint",
    "agent:mvp": "pnpm --filter @product-intelligence-agent/agent-mvp start",
    "agent:mvp-dev": "pnpm --filter @product-intelligence-agent/agent-mvp dev",
    "agent:mvp:build": "pnpm --filter @product-intelligence-agent/agent-mvp build",
    "agent:mvp:typecheck": "pnpm --filter @product-intelligence-agent/agent-mvp typecheck",
    "db:up": "docker compose up -d postgres",
    "db:down": "docker compose down",
    "db:logs": "docker compose logs -f postgres"
  },
  "devDependencies": {
    "@tsconfig/node20": "^20.1.6",
    "typescript": "^5.8.3"
  },
  "dependencies": {
    "openai": "^6.44.0",
    "zod": "^4.4.3"
  }
}
